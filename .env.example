# Supabase (engine — projeto NOVO, não o do precoremedio)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Modelos (tier gratuito)
# LLM + Visão: Google Gemini free tier — texto do conselho + extração de estilo (multimodal)
GEMINI_API_KEY=
# (opcional/pago) alternativa pluggable: Anthropic. Deixe vazio p/ usar só o free.
ANTHROPIC_API_KEY=

# Imagem (mascote/posts) — failover automático entre estes, todos grátis:
# 1) NVIDIA NIM — QUALIDADE (Qwen-Image): hospedado, sem GPU, créditos grátis.
#    Crie a chave nvapi- grátis (sem cartão) em build.nvidia.com.
NVIDIA_API_KEY=
#    IMAGEM: cole o endpoint EXATO do model card (build.nvidia.com/qwen/qwen-image → painel de código).
#    Só com NVIDIA_IMAGE_URL setado o provider de imagem do NVIDIA entra (senão usa Flux).
#    O TEXTO (LLM) já funciona sem isto, via NVIDIA_BASE_URL (chat/completions).
# NVIDIA_IMAGE_URL=
NVIDIA_IMAGE_MODEL=qwen/qwen-image-2512
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# 2) Cloudflare Workers AI (FLUX.1 schnell) — VOLUME: 10k/dia, sem cartão (fallback).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
# 3) Gemini Nano Banana — usa a GEMINI_API_KEY acima (geração free=429 hoje, fica de reserva).
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Texto/LLM (conselho roteirista) — failover best-first (melhor grátis → inferior):
# 1) NVIDIA NIM (LLM forte: Llama-3.3-70B / DeepSeek etc.) — usa a NVIDIA_API_KEY acima.
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct
# 2) OpenRouter (modelos :free) — crie a chave grátis em openrouter.ai.
OPENROUTER_API_KEY=
OPENROUTER_LLM_MODEL=deepseek/deepseek-chat-v3.1:free
# 3) Gemini 2.5-flash — usa a GEMINI_API_KEY acima (fallback, já funciona hoje).

# Failover / alertas (opcionais)
# ALLOW_PAID=false                                # liga providers c/ cartão (ex.: GCP). Default: só grátis.
# IMAGE_PROVIDER_ORDER=cloudflare-flux,nvidia-nim # reordena (ex.: Flux 1º p/ conservar créditos do NIM)
# PROVIDER_COOLDOWN_MS=60000                       # tempo que um provider "down" fica pulado
# RESEND_API_KEY=                                  # alerta por e-mail quando um provider cai
# ALERT_EMAIL=
# ALERT_FROM=content-engine <onboarding@resend.dev>

# Voz: Edge TTS (msedge-tts) — neural PT-BR, GRÁTIS e SEM key. Nada a preencher aqui.
# Fallback 100% local/offline: Piper.

# Storage — usa o Supabase Storage do PRÓPRIO engine (bucket privado "media").
# Não precisa de variável extra: reaproveita SUPABASE_URL + SERVICE_ROLE_KEY acima.
# (Futuro, só quando o volume justificar) Cloudflare R2:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=content-engine

# Conector de nicho -> engine (contrato de ingestão)
ENGINE_INGEST_URL=
INGEST_TOKEN=
