# Supabase (engine — projeto NOVO, não o do precoremedio)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Modelos (tier gratuito)
# LLM + Visão: Google Gemini free tier — texto do conselho + extração de estilo (multimodal)
GEMINI_API_KEY=
# (opcional/pago) alternativa pluggable: Anthropic. Deixe vazio p/ usar só o free.
ANTHROPIC_API_KEY=

# Voz: Edge TTS (msedge-tts) — neural PT-BR, GRÁTIS e SEM key. Nada a preencher aqui.
# Fallback 100% local/offline: Piper.

# Storage — usa o Supabase Storage do PRÓPRIO engine (bucket privado "media").
# Não precisa de variável extra: reaproveita SUPABASE_URL + SERVICE_ROLE_KEY acima.
# (Futuro, só quando o volume justificar) Cloudflare R2:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=content-engine

# Conector de nicho -> engine (contrato de ingestão)
ENGINE_INGEST_URL=
INGEST_TOKEN=
